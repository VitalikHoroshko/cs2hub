<%- include('../partials/header') %>

<main class="container">
  <section class="admin-page">
    <div class="admin-page-top">
      <div>
        <p class="admin-kicker">Edit</p>
        <h1>Edit Post</h1>
        <p class="admin-subtext">Update content, image, and post settings.</p>
      </div>

      <div class="admin-actions">
        <a href="/admin" class="btn-secondary">Back</a>
      </div>
    </div>

    <div class="admin-form-card">
      <form method="POST" action="/admin/posts/edit/<%= post.id %>" class="admin-form" enctype="multipart/form-data">
        <div class="form-grid">
          <div class="form-field form-field-full">
            <label>Title</label>
            <input type="text" name="title" id="title" value="<%= typeof post.title === 'string' ? post.title : '' %>" required>
          </div>

          <div class="form-field">
            <label>Slug</label>
            <input type="text" name="slug" id="slug" value="<%= typeof post.slug === 'string' ? post.slug : '' %>" required>
          </div>

          <div class="form-field">
            <label>Category</label>
            <select name="category" required>
              <option value="guides" <%= post.category === 'guides' ? 'selected' : '' %>>Guides</option>
              <option value="top-lists" <%= post.category === 'top-lists' ? 'selected' : '' %>>Top Lists</option>
              <option value="pro-settings" <%= post.category === 'pro-settings' ? 'selected' : '' %>>Pro Settings</option>
              <option value="news" <%= post.category === 'news' ? 'selected' : '' %>>News</option>
              <option value="gear" <%= post.category === 'gear' ? 'selected' : '' %>>Gear</option>
            </select>
          </div>

          <div class="form-field">
            <label>Image Path</label>
            <input type="text" name="image" value="<%= typeof post.image === 'string' ? post.image : '' %>">
          </div>

          <div class="form-field">
            <label>Replace Image</label>
            <input type="file" name="imageFile" accept="image/*">
          </div>

          <div class="form-field form-field-full">
            <label>Excerpt</label>
            <input type="text" name="excerpt" value="<%= typeof post.excerpt === 'string' ? post.excerpt : '' %>" required>
          </div>

          <div class="form-field">
            <label>Date</label>
            <input type="date" name="date" value="<%= typeof post.date === 'string' ? post.date : '' %>" required>
          </div>

          <div class="form-field checkbox-field">
            <label class="checkbox-row">
              <input type="checkbox" name="featured" <%= post.featured === 1 || post.featured === true ? 'checked' : '' %>>
              Featured post
            </label>
          </div>

          <div class="form-field form-field-full">
            <label>Content</label>
            <textarea name="content" rows="14" required><%= typeof post.content === 'string' ? post.content : '' %></textarea>
          </div>
        </div>

        <div class="admin-actions">
          <button type="submit" class="btn-primary">Save Changes</button>
          <a href="/admin" class="btn-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </section>
</main>

<script>
  const titleInput = document.getElementById("title");
  const slugInput = document.getElementById("slug");

  function makeSlug(value) {
    return value
      .toLowerCase()
      .trim()
      .replace(/[^a-z0-9\\s-]/g, "")
      .replace(/\\s+/g, "-")
      .replace(/-+/g, "-");
  }

  titleInput.addEventListener("input", () => {
    if (!slugInput.dataset.edited) {
      slugInput.value = makeSlug(titleInput.value);
    }
  });

  slugInput.addEventListener("input", () => {
    slugInput.dataset.edited = "true";
  });
</script>

<%- include('../partials/footer') %>